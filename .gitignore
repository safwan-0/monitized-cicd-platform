# Terraform state — contains real AWS account details
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variables with real values — contains passwords
terraform.tfvars

# Keep the example file
!terraform.tfvars.example

# Python
__pycache__/
*.pyc
.env

# OS files
.DS_Store
Thumbs.db

# Runner registration token — never commit this
runner-setup/.runner
runner-setup/.credentials
